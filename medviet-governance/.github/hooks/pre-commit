#!/bin/bash
# Pre-commit hook: run security checks before commit

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_DIR="$REPO_ROOT/medviet-governance"

if [ -d "$PROJECT_DIR/src" ]; then
    APP_DIR="$PROJECT_DIR"
else
    APP_DIR="$REPO_ROOT"
fi

echo "Running security checks..."

# 1. git-secrets scan
git secrets --pre_commit_hook -- "$@"
if [ $? -ne 0 ]; then
    echo "git-secrets found potential secrets. Commit blocked."
    exit 1
fi

# 2. Bandit SAST scan
echo "Running Bandit SAST..."
cd "$APP_DIR" || exit 1

if command -v bandit >/dev/null 2>&1; then
    BANDIT_CMD="bandit"
elif [ -x "$REPO_ROOT/.venv/Scripts/bandit.exe" ]; then
    BANDIT_CMD="$REPO_ROOT/.venv/Scripts/bandit.exe"
else
    echo "bandit is not available. Install requirements or activate the venv."
    exit 1
fi

"$BANDIT_CMD" -r src/ -ll -q
if [ $? -ne 0 ]; then
    echo "Bandit found security issues. Review above."
    exit 1
fi

# 3. pip-audit dependency check
echo "Checking dependencies for CVEs..."
if command -v pip-audit >/dev/null 2>&1; then
    PIP_AUDIT_CMD="pip-audit"
elif [ -x "$REPO_ROOT/.venv/Scripts/pip-audit.exe" ]; then
    PIP_AUDIT_CMD="$REPO_ROOT/.venv/Scripts/pip-audit.exe"
else
    echo "pip-audit is not available. Install requirements or activate the venv."
    exit 1
fi

"$PIP_AUDIT_CMD" --desc on
if [ $? -ne 0 ]; then
    echo "Vulnerable dependencies found. Update before committing."
    exit 1
fi

echo "All security checks passed."
exit 0
